# ---------------------------------------------------------------------------
# AfriTech Bridge Intern Portal — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and customize as needed.
#
# VITE_BACKEND_URL: Root URL of the AfriTech Bridge backend (no trailing slash).
#
#   Production:  https://study.afritechbridge.online
#   Local dev:   http://127.0.0.1:5000   (or whatever port Flask runs on)
#
# If omitted, the app defaults to the production URL.
#
VITE_BACKEND_URL="https://study.afritechbridge.online"
